  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Calculate Process Time"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{75F1CEE8-9E71-48D6-A4B3-DC76D7DE5F17}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Calculate Process Time"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D6897CF0-026C-49EE-8BA6-C6C462F756FA}"
          SQLTask:SqlStatementSource="UPDATE dbo.FactSales&#xA;SET &#xA;    txn_process_time_hours = DATEDIFF(minute, accm_txn_create_time, accm_txn_complete_time) / 60.0&#xA;WHERE SalesDate IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update create and complete time columns in FactSales  (Sales Date &amp; Delivery Date)"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{85A203F0-25B8-49D6-8188-3DF8880508AF}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update create and complete time columns in FactSales  (Sales Date &amp; Delivery Date)"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{D6897CF0-026C-49EE-8BA6-C6C462F756FA}"
          SQLTask:SqlStatementSource="UPDATE dbo.FactSales&#xA;SET &#xA;    accm_txn_create_time = CAST(SalesDate AS DATETIME),&#xA;    accm_txn_complete_time = CASE&#xA;        WHEN StoreLocation = 'Online'&#xA;        THEN DATEADD(&#xA;                day, &#xA;                ABS(CHECKSUM(NEWID()) % 10) + 1,&#xA;                CAST(SalesDate AS DATETIME)&#xA;             )&#xA;        ELSE CAST(SalesDate AS DATETIME)  -- Non-Online = SalesDate එකම ✅&#xA;    END&#xA;WHERE SalesDate IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
